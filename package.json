{
  "name": "memfs-extra",
  "version": "1.0.3",
  "description": "為 memfs 提供 fs-extra 的 API 擴展支援 (Providing fs-extra API extension support for memfs)",
  "keywords": [
    "memfs",
    "fs-extra",
    "fs",
    "extension",
    "api",
    "mock",
    "virtual-fs",
    "create-by-yarn-tool"
  ],
  "homepage": "https://github.com/bluelovers/memfs-extra#readme",
  "bugs": {
    "url": "https://github.com/bluelovers/memfs-extra/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluelovers/memfs-extra.git"
  },
  "license": "ISC",
  "author": "",
  "sideEffects": false,
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "review": "node --run review:coverage",
    "review:coverage": "yarn run lint && yarn run coverage",
    "review:test": "yarn run lint && yarn run test",
    "coverage": "yarn run test -- --coverage",
    "lint": "node --run lint:eslint --",
    "lint:eslint": "ynpx eslint --ext .ts,.tsx,.mts,.cts ./",
    "pretest": "pnpm run build",
    "test": "node --run test:jest:snapshot --",
    "test:jest": "jest --passWithNoTests",
    "test:jest:clearCache": "jest --clearCache",
    "test:jest:coverage": "node --run test:jest -- --coverage",
    "test:jest:snapshot": "node --run test:jest -- -u",
    "test:mocha": "ynpx --quiet -p ts-node -p mocha mocha -- --require ts-node/register \"!(node_modules)/**/*.{test,spec}.{ts,tsx}\"",
    "test:snapshot": "yarn run test -- -u",
    "test:tsd": "ynpx tsd",
    "test:tsdx": "ynpx @bluelovers/tsdx test --passWithNoTests",
    "install:frozenLockfile": "yarn-tool install --frozen-lockfile",
    "install:resetLockfile": "yarn-tool install --reset-lockfile",
    "build": "tsc",
    "build:dts:bundle": "ynpx @bluelovers/dts-bundle-generator -o ./dist/index.d.ts ./src/index.ts --no-banner --inline-declare-global & echo build:dts:bundle",
    "build:dts:copy": "copy .\\src\\index.d.ts .\\dist\\index.d.ts & echo build:dts",
    "build:dts:tsc": "node --run build:dts:tsc:emit && node --run build:dts:copy",
    "build:dts:tsc:emit": "tsc --emitDeclarationOnly --declaration --noEmit false",
    "build:microbundle": "ynpx microbundle --target node",
    "build:tsdx": "ynpx @bluelovers/tsdx build --target node --name index",
    "ci:install": "node --run ci:install:pnpm",
    "ci:install:pnpm": "pnpm install --frozen-lockfile && pnpm add --workspace yarn-tool lerna ynpx pnpm typescript ts-node tsx ts-jest jest @bluelovers/jest-config @bluelovers/tsconfig @yarn-tool/require-resolve",
    "ci:install:yarn": "yarn install --frozen-lockfile && yarn add -W yarn-tool lerna ynpx pnpm typescript ts-node tsx ts-jest jest @bluelovers/jest-config @bluelovers/tsconfig @yarn-tool/require-resolve",
    "ci:build": "echo ci:build",
    "npm:publish": "npm publish",
    "npm:publish:bump": "node --run version:bump && npm publish",
    "npm:publish:bump:major": "node --run version:bump -- --bump major && npm publish",
    "npm:publish:bump:minor": "node --run version:bump -- --bump minor && npm publish",
    "npm:publish:bump:patch": "node --run version:bump -- --bump patch && npm publish",
    "npm:publish:bump:prerelease": "node --run version:bump -- --bump prerelease && npm publish",
    "pnpm:dedupe": "pnpm dedupe",
    "ws:fix-all": "yarn-tool fix-all --overwriteHostedGitInfo",
    "ws:fix-all:resetStaticFiles": "node --run ws:fix-all -- --resetStaticFiles",
    "preversion": "echo preversion && yarn run test",
    "version": "echo version",
    "version:bump": "yarn-tool version",
    "version:bump:major": "node --run version:bump -- --bump major",
    "version:bump:minor": "node --run version:bump -- --bump minor",
    "version:bump:patch": "node --run version:bump -- --bump patch",
    "version:bump:prerelease": "node --run version:bump -- --bump prerelease",
    "postversion": "echo postversion",
    "prepublish": "echo prepublish",
    "prepare": "echo prepare",
    "prepublishOnly": "yarn run preversion",
    "prepublishOnly:check-bin": "ynpx --quiet @yarn-tool/check-pkg-bin",
    "prepack": "echo prepack",
    "pack": "echo pack",
    "postpack": "echo postpack",
    "publish": "echo publish",
    "postpublish": "node --run postpublish:changelog && node --run postpublish:git:commit && node --run postpublish:git:tag && node --run postpublish:git:push",
    "postpublish:changelog": "ynpx --quiet @yarn-tool/changelog && git add ./CHANGELOG.md",
    "postpublish:git:commit": "git commit -m \"chore(release): publish\" . & echo postpublish:git:commit",
    "postpublish:git:push": "git push --follow-tags",
    "postpublish:git:tag": "ynpx --quiet @yarn-tool/tag",
    "postpublishOnly": "echo postpublishOnly",
    "ncu": "yarn-tool ncu -u",
    "ncu:pnpm": "pnpm update",
    "sort-package-json": "yarn-tool sort",
    "tsc:default": "tsc -p tsconfig.json",
    "tsc:esm": "tsc -p tsconfig.esm.json",
    "tsc:showConfig": "ynpx get-current-tsconfig -p"
  },
  "dependencies": {
    "ts-type": "^3.0.13",
    "ts-type-predicates": "^1.0.13",
    "tslib": "^2.8.1",
    "upath2": "^3.1.23"
  },
  "devDependencies": {
    "@bluelovers/tsconfig": "^1.0.35",
    "@jsonjoy.com/fs-node-utils": "^4.57.1",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@yarn-tool/require-resolve": "^4.0.6",
    "@yarn-tool/ws-find-up-paths": "^1.0.19",
    "fs-extra": "^11.3.4",
    "jest": "^30.3.0",
    "memfs": "^4.57.1",
    "unionfs": "^4.6.0"
  }
}
